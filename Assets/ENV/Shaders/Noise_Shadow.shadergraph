{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "db55adee9ef84c0290513c9c80c90b6c",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "MainLight (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -2495.999755859375,
            "y": -906.0,
            "width": 212.0,
            "height": 326.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "e87bfa3656ea4dbc8128a9e8e5617c0d"
        },
        {
            "m_Id": "7fabff32135b4645b660519e431fc9f5"
        },
        {
            "m_Id": "eb6fb9a93689484d8a39adacb51e612b"
        },
        {
            "m_Id": "1d1d93ee4b834706aec172a58259f89b"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "MainLight",
    "m_FunctionSource": "bd1a8838e5e30f34f8c1425314ac2cc6",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/Lighting.hlsl\"\n\nfloat3 AccumulatePointLights(float3 worldPos, float3 normal)\r\n{\r\n    float3 totalLight = 0;\r\n    for (int i = 0; i < GetAdditionalLightsCount(); ++i)\r\n    {\r\n        Light light = GetAdditionalLight(i, worldPos);\r\n        float3 lightDir = normalize(light.direction);\r\n        float NdotL = saturate(dot(normal, lightDir));\r\n        float3 lightContribution = NdotL * light.color * light.distanceAttenuation * light.shadowAttenuation;\r\n        totalLight += lightContribution;\r\n    }\r\n    return totalLight;\r\n}"
}

